{
	"name": "Node.js",
	"image": "ghcr.io/innoq-trainings/agentic-se-image:latest",
	"runArgs": [
		"--init",
		"--privileged"
	],
	"mounts": [
		"source=dind-var-lib-docker,target=/var/lib/docker,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"esbenp.prettier-vscode",
				"DavidAnson.vscode-markdownlint",
				"bierner.markdown-mermaid",
				"pomdtr.markdown-kroki",
				"redhat.java",
				"vscjava.vscode-java-debug",
				"vscjava.vscode-java-test",
				"vmware.vscode-spring-boot",
				"vscjava.vscode-spring-initializr",
				"vscjava.vscode-spring-boot-dashboard",
				"fwcd.kotlin"
			]
		}
	},
	"secrets": {
		"ANTHROPIC_API_KEY": {
			"description": "Hier musst du den API-Key eintragen. Du bekommst ihn von einem Trainer"
		},
		"GITHUB_PERSONAL_ACCESS_TOKEN": {
			"description": "GitHub Personal Access Token (PAT) für den GitHub-MCP-Server. Erstellen unter https://github.com/settings/tokens (Scopes z. B. repo, read:org). Optional – ohne Token bleibt der github-MCP-Server inaktiv."
		}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {
	// },

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// "containerEnv": {},
	"postStartCommand": "sudo /usr/local/share/docker-init.sh"
}